# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
# Service Role Key (server-side only, NEVER expose to client!)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Domain Configuration
# Production root domain (without protocol)
NEXT_PUBLIC_ROOT_DOMAIN=boost-hive.de
# Local development domain (default: localhost)
LOCAL_DOMAIN=localhost

# Stripe (added in PROJ-14)
# Server-side secret key (NEVER expose to client!)
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
# Webhook endpoint signing secret (from Stripe Dashboard → Webhooks)
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-signing-secret
# Price ID for the Basis-Plan (28-day interval, configured in Stripe Dashboard)
STRIPE_BASIS_PLAN_PRICE_ID=price_your-basis-plan-price-id
# Client-side publishable key
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-publishable-key

# Email (Mailtrap API - added in PROJ-4 / used by PROJ-5)
MAILTRAP_MODE=live
MAILTRAP_API_TOKEN=your-mailtrap-api-token
MAILTRAP_FROM=noreply@boost-hive.de
# Required only for sandbox mode:
# MAILTRAP_INBOX_ID=your-sandbox-inbox-id

# AI Visibility Tool (PROJ-12)
OPENROUTER_API_KEY=your_openrouter_api_key
# Optional: Secret to protect the internal worker endpoint
VISIBILITY_WORKER_SECRET=your_random_secret

# Google Search Console Integration (PROJ-26)
# From Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client ID
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your-google-client-secret
# App base URL (used as redirect_uri base for OAuth callback)
NEXT_PUBLIC_APP_URL=http://localhost:3000
# AES-256 key for encrypting GSC tokens (must be exactly 32 bytes = 64 hex chars)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
GSC_ENCRYPTION_KEY=your_64_hex_char_encryption_key
# HMAC secret for OAuth state tokens (min. 16 chars, prefer 32+)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
GSC_STATE_SECRET=your_random_state_secret

# Content Brief Generator (PROJ-31)
# Secret to protect the internal worker endpoint
CONTENT_WORKER_SECRET=your_random_content_worker_secret
# Optional: Override the default AI model (default: anthropic/claude-3.5-sonnet)
# CONTENT_BRIEF_MODEL=anthropic/claude-3.5-sonnet

# Brand Trends / Google Trends (PROJ-66)
# SerpAPI key for the Google Trends endpoint
# Sign up at https://serpapi.com — used by /api/tenant/brand-trends
SERPAPI_KEY=your_serpapi_key
